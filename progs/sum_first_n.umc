.START: ; first n numbers to sum
	mov u32:0, #10
	; counter
	mov u32:1, #0
	; result
	mov u32:2, #0

.LOOP: ; increment i
	add u32:1, u32:1, #1
	dbg u32:1
	; Add counter to result
	add u32:2, u32:2, u32:1
	; Check if they are the same
	xor u32:8, u32:1, u32:0
	; Negate
	bz .EXIT, u32:8
	jmp .LOOP
.EXIT:
	dbg u32:2
